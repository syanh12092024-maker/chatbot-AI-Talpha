# Sao chép file này thành .env rồi điền giá trị thật.

# Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Facebook Messenger (Meta App → Messenger → Webhooks)
PAGE_ACCESS_TOKEN=EAAB...          # token 1 page (chế độ 1 page; bỏ trống nếu dùng đa-page bên dưới)
VERIFY_TOKEN=tu_dat_mot_chuoi_bi_mat   # dùng để verify webhook với Meta
APP_SECRET=                         # App Secret — để verify chữ ký X-Hub-Signature-256 (khuyến nghị)

# ĐA-PAGE (200 page): System User token của Business Manager. Có cái này thì
# server tự kéo token TẤT CẢ page qua /me/accounts, không cần PAGE_ACCESS_TOKEN.
META_SYSTEM_TOKEN=
GRAPH_VERSION=v21.0

# Knowledge Base (file Excel team điền)
KB_PATH=../KB_Pages.xlsx

# Models
MODEL_CLOSER=claude-haiku-4-5
MODEL_CLASSIFIER=claude-haiku-4-5

# Server
PORT=3100

# URL công khai (cloudflared/ngrok) — BẮT BUỘC để bot gửi được ẢNH sản phẩm cho khách.
# Ảnh upload từ dashboard được host tại <PUBLIC_URL>/uploads/... để Facebook tải về.
# Ví dụ: PUBLIC_URL=https://abc-xyz.trycloudflare.com
PUBLIC_URL=

# Pancake CRM (để tạo đơn) — điền khi đấu nối thật
PANCAKE_API_KEY=
PANCAKE_SHOP_ID=
